# ─────────────────────────────────────────────────────────────
# Onishi — variables d'environnement
# ─────────────────────────────────────────────────────────────
#
# SANS ces variables, l'app tourne en MODE DÉMO (menu en seed local,
# commandes stockées dans le navigateur). Idéal pour pitcher.
#
# Dès que ces deux variables sont définies, l'app bascule sur Supabase
# (menu, commandes, auth staff, realtime) — voir README.

# URL du projet Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Clé "anon"/publishable (sûre côté client, protégée par les policies RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── NE JAMAIS exposer la service_role côté client. ──
# Réservée à d'éventuelles tâches serveur d'admin (non utilisée en v1).
# SUPABASE_SERVICE_ROLE_KEY=
